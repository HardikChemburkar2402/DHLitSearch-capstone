# OpenAlex (no key needed, just add email for faster responses)
OPENALEX_EMAIL=hardikchemburkar@arizona.edu

# Gemini API for RAG/QA pipeline (AI Studio fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# Route Gemini through Vertex AI (recommended — higher rate limits, uses GCP credits).
# Leave these blank to force AI Studio (API-key) mode.
# Make sure `gcloud auth application-default login` has been run so ADC works.
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1
